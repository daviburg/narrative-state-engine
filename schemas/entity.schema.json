{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "entity.schema.json",
  "title": "Entity (V2)",
  "description": "A named entity in the game world: character, location, faction, item, creature, or concept. V2 schema with identity/status split, stable/volatile attributes, and consolidated relationships.",
  "type": "object",
  "required": ["id", "name", "type", "identity", "first_seen_turn"],
  "additionalProperties": false,
  "allOf": [
    { "if": { "properties": { "type": { "const": "character" } } },  "then": { "properties": { "id": { "pattern": "^char-" } } } },
    { "if": { "properties": { "type": { "const": "location" } } },  "then": { "properties": { "id": { "pattern": "^loc-" } } } },
    { "if": { "properties": { "type": { "const": "faction" } } },   "then": { "properties": { "id": { "pattern": "^faction-" } } } },
    { "if": { "properties": { "type": { "const": "item" } } },      "then": { "properties": { "id": { "pattern": "^item-" } } } },
    { "if": { "properties": { "type": { "const": "creature" } } },  "then": { "properties": { "id": { "pattern": "^creature-" } } } },
    { "if": { "properties": { "type": { "const": "concept" } } },   "then": { "properties": { "id": { "pattern": "^concept-" } } } }
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier with type prefix, e.g. 'char-innkeeper', 'loc-thornhaven', 'faction-iron-ridge'.",
      "pattern": "^(char|loc|faction|item|creature|concept)-[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "description": "Display name of the entity.",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "description": "Entity category.",
      "enum": ["character", "location", "faction", "item", "creature", "concept"]
    },
    "identity": {
      "type": "string",
      "description": "Stable identity summary: who/what the entity is. 2-3 sentences."
    },
    "current_status": {
      "type": "string",
      "description": "Volatile status: what the entity is doing/experiencing now. 1-3 sentences."
    },
    "status_updated_turn": {
      "type": "string",
      "description": "Turn when current_status was last updated.",
      "pattern": "^turn-[0-9]{3,}$"
    },
    "stable_attributes": {
      "type": "object",
      "description": "Persistent traits (race, class, appearance, role). Rarely change.",
      "additionalProperties": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "inference": { "type": "boolean", "default": false },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "source_turn": { "type": "string", "pattern": "^turn-[0-9]{3,}$" }
        },
        "additionalProperties": false
      }
    },
    "volatile_state": {
      "type": "object",
      "description": "Current state: condition, equipment, location. Updated each turn entity appears.",
      "properties": {
        "condition": { "type": "string" },
        "equipment": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "last_updated_turn": { "type": "string", "pattern": "^turn-[0-9]{3,}$" }
      },
      "additionalProperties": true
    },
    "relationships": {
      "type": "array",
      "description": "Consolidated per-pair relationships to other entities.",
      "items": {
        "type": "object",
        "required": ["target_id", "current_relationship", "type", "first_seen_turn"],
        "additionalProperties": false,
        "properties": {
          "target_id": {
            "type": "string",
            "description": "ID of the related entity."
          },
          "current_relationship": {
            "type": "string",
            "description": "Current state of the relationship."
          },
          "type": {
            "type": "string",
            "description": "Category of relationship.",
            "enum": ["kinship", "partnership", "mentorship", "political", "factional", "social", "adversarial", "romantic", "spatial", "other"]
          },
          "direction": {
            "type": "string",
            "description": "Directionality of the relationship from this entity's perspective.",
            "enum": ["outgoing", "incoming", "bidirectional"]
          },
          "status": {
            "type": "string",
            "description": "Temporal status of the relationship.",
            "enum": ["active", "dormant", "resolved"],
            "default": "active"
          },
          "confidence": {
            "type": "number",
            "description": "Confidence in this relationship (0.0-1.0). Omit if explicit.",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "first_seen_turn": {
            "type": "string",
            "description": "Turn ID when this relationship was first established.",
            "pattern": "^turn-[0-9]{3,}$"
          },
          "last_updated_turn": {
            "type": "string",
            "description": "Turn ID of the most recent change to this relationship.",
            "pattern": "^turn-[0-9]{3,}$"
          },
          "resolved_turn": {
            "type": "string",
            "description": "Turn ID when the relationship was resolved.",
            "pattern": "^turn-[0-9]{3,}$"
          },
          "resolution_note": {
            "type": "string",
            "description": "Explanation of how/why the relationship ended."
          },
          "history": {
            "type": "array",
            "description": "Append-only log of significant relationship changes.",
            "items": {
              "type": "object",
              "required": ["turn", "description"],
              "properties": {
                "turn": { "type": "string", "pattern": "^turn-[0-9]{3,}$" },
                "description": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      }
    },
    "first_seen_turn": {
      "type": "string",
      "description": "Turn ID when this entity was first mentioned.",
      "pattern": "^turn-[0-9]{3,}$"
    },
    "last_updated_turn": {
      "type": "string",
      "description": "Turn ID of the most recent update.",
      "pattern": "^turn-[0-9]{3,}$"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes, open questions, or player hypotheses about this entity."
    }
  }
}
