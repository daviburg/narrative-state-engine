{
  "provider": "openai",
  "base_url": "http://localhost:8000/v1",
  "base_urls": [
    "http://localhost:8000/v1",
    "http://localhost:8001/v1"
  ],
  "model": "qwen3-8b-int4-ov",
  "api_key_env": "",
  "temperature": 0.3,
  "max_tokens": 4096,
  "discovery_max_tokens": 8192,
  "pc_max_tokens": 8192,
  "timeout_seconds": 300,
  "retry_attempts": 3,
  "batch_delay_ms": 0,
  "parallel_workers": 1,
  "context_length": 32768,
  "entity_refresh_interval": 50,
  "entity_refresh_batch_size": 10,
  "checkpoint_interval": 25,
  "dedup_audit_interval": 50,
  "skip_response_format": true,
  "context_optimizations": {
    "adaptive_compression": {
      "enabled": false,
      "pressure_gate_fraction": 0.45,
      "discovery_floor_fraction": 0.25,
      "turn_total_budget_fraction": 0.85,
      "centrality_min_degree": 2,
      "centrality_exempt_top_n": null
    }
  }
}
